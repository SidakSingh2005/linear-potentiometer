st.ts\"\n    ],\n    \"targetVersions\": {\n        \"branch\": \"v6.0.25\",\n        \"tag\": \"v6.0.25\",\n        \"commits\": \"https://github.com/microsoft/pxt-microbit/commits/f72136f1d01face3fc76caffa5343af1db369a37\",\n        \"target\": \"7.0.57\",\n        \"pxt\": \"9.0.15\",\n        \"targetId\": \"microbit\"\n    },\n    \"supportedTargets\": [\n        \"microbit\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n","test.ts":"// tests go here; this will not be compiled when this package is used as an extension.\n"}},{"timestamp":1773947886708,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"XI=eSZ~Ux!s9l*4ll_{p\">current</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block><block type=\"device_forever\" x=\"205\" y=\"0\"><statement name=\"HANDLER\"><block type=\"device_show_number\"><value name=\"number\"><block type=\"device_get_analog_pin\"><value name=\"name\"><shadow type=\"analog_read_write_pin_shadow\"><field name=\"pin\">AnalogReadWritePin.P0</field></shadow></value></block></value><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">500</field></shadow></value></block></next></block></statement></block></xml>","main.ts":"let sensorValue = 0\nlet ledPosition = 0\n\nbasic.forever(function () {\n\n    sensorValue = pins.analogReadPin(AnalogReadWritePin.P0)\n\n    // map value to 0–4\n    ledPosition = Math.map(sensorValue, 0, 1023, 0, 4)\n    ledPosition = Math.round(ledPosition)\n\n    // keep in range\n    if (ledPosition < 0) {\n        ledPosition = 0\n    } else if (ledPosition > 4) {\n        ledPosition = 4\n    }\n\n    basic.clearScreen()\n\n    // 🔥 PROGRESS BAR STYLE (unique look)\n    for (let i = 0; i <= ledPosition; i++) {\n        led.plot(i, 2)\n    }\n\n    // 🔊 SOUND BASED ON POSITION\n    let tone = Math.map(ledPosition, 0, 4, 200, 1000)\n    music.playTone(tone, 50)\n\n 